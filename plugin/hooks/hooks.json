{
  "description": "Non-blocking scan for AI writing tells in prose files after they're written or edited.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/hook_detect.py",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
